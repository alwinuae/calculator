<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:orientation="vertical">

    <!-- Display Area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.2"
        android:background="@color/bg_display"
        android:gravity="bottom"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="16dp">

        <TextView
            android:id="@+id/tvExpression"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:maxLines="2"
            android:ellipsize="start"
            android:text=""
            android:textColor="@color/text_expression"
            android:textSize="22sp"
            android:fontFamily="sans-serif-light"
            android:paddingBottom="8dp" />

        <TextView
            android:id="@+id/tvResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:text="0"
            android:textColor="@color/text_primary"
            android:textSize="56sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:maxLines="1"
            android:autoSizeTextType="uniform"
            android:autoSizeMinTextSize="28sp"
            android:autoSizeMaxTextSize="56sp" />

    </LinearLayout>

    <!-- Subtle divider line -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:background="@color/divider" />

    <!-- Buttons Grid -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2.4"
        android:columnCount="4"
        android:rowCount="5"
        android:padding="8dp"
        android:useDefaultMargins="false">

        <!-- Row 1: C, (), %, ÷ -->
        <Button android:id="@+id/btnClear" style="@style/CalcButtonFunction" android:text="C" android:textColor="@color/accent_pink" />
        <Button android:id="@+id/btnParens" style="@style/CalcButtonFunction" android:text="( )" />
        <Button android:id="@+id/btnPercent" style="@style/CalcButtonFunction" android:text="%" />
        <Button android:id="@+id/btnDivide" style="@style/CalcButtonOperator" android:text="÷" />

        <!-- Row 2: 7, 8, 9, × -->
        <Button android:id="@+id/btn7" style="@style/CalcButtonNumber" android:text="7" />
        <Button android:id="@+id/btn8" style="@style/CalcButtonNumber" android:text="8" />
        <Button android:id="@+id/btn9" style="@style/CalcButtonNumber" android:text="9" />
        <Button android:id="@+id/btnMultiply" style="@style/CalcButtonOperator" android:text="×" />

        <!-- Row 3: 4, 5, 6, - -->
        <Button android:id="@+id/btn4" style="@style/CalcButtonNumber" android:text="4" />
        <Button android:id="@+id/btn5" style="@style/CalcButtonNumber" android:text="5" />
        <Button android:id="@+id/btn6" style="@style/CalcButtonNumber" android:text="6" />
        <Button android:id="@+id/btnMinus" style="@style/CalcButtonOperator" android:text="-" />

        <!-- Row 4: 1, 2, 3, + -->
        <Button android:id="@+id/btn1" style="@style/CalcButtonNumber" android:text="1" />
        <Button android:id="@+id/btn2" style="@style/CalcButtonNumber" android:text="2" />
        <Button android:id="@+id/btn3" style="@style/CalcButtonNumber" android:text="3" />
        <Button android:id="@+id/btnPlus" style="@style/CalcButtonOperator" android:text="+" />

        <!-- Row 5: +/-, 0, ., = -->
        <Button android:id="@+id/btnPlusMinus" style="@style/CalcButtonNumber" android:text="+/-" android:textSize="18sp" />
        <Button android:id="@+id/btn0" style="@style/CalcButtonNumber" android:text="0" />
        <Button android:id="@+id/btnDot" style="@style/CalcButtonNumber" android:text="." />
        <Button android:id="@+id/btnEquals" style="@style/CalcButtonEquals" android:text="=" />

    </GridLayout>

</LinearLayout>
